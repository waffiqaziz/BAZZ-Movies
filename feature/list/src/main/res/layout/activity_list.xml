<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/activity_list"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/gray_900"
  tools:context=".ui.ListActivity">

  <com.google.android.material.appbar.AppBarLayout
    android:id="@+id/appBarLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@null"
    android:fitsSystemWindows="true"
    android:translationZ="0.1dp"
    app:subtitleCentered="false"
    app:titleCentered="false">

    <com.google.android.material.appbar.CollapsingToolbarLayout
      android:id="@+id/collapse"
      android:layout_width="match_parent"
      android:layout_height="?attr/collapsingToolbarLayoutLargeSize"
      app:collapsedSubtitleTextColor="@color/gray_400"
      app:collapsedTitleTextAppearance="@style/CollapsedTitleStyle"
      app:collapsedTitleTextColor="@color/gray_200"
      app:contentScrim="@color/gray_1000"
      app:expandedSubtitleTextAppearance="@style/CollapsedTitleStyle"
      app:expandedSubtitleTextColor="@color/gray_400"
      app:expandedTitleGravity="bottom|center_horizontal"
      app:expandedTitleTextAppearance="@style/CollapsedHeaderTitleStyle"
      app:expandedTitleTextColor="@color/gray_200"
      app:layout_scrollFlags="scroll|snap|exitUntilCollapsed"
      app:subtitleCentered="false"
      app:titleCentered="false"
      app:titleCollapseMode="fade">

      <ImageView
        android:id="@+id/iv_picture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/poster"
        android:fitsSystemWindows="true"
        android:foreground="@drawable/bg_gradient_shape"
        android:scaleType="centerCrop"
        app:layout_collapseMode="parallax"
        app:layout_collapseParallaxMultiplier="0.7"
        tools:layout_height="350dp"
        tools:src="@tools:sample/backgrounds/scenic" />

      <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="0dp"
        android:translationY="-4dp"
        app:layout_collapseMode="pin"
        app:subtitleCentered="false"
        app:titleCentered="false"
        tools:subtitle="Medium Subtitle"
        tools:title="Medium Title">

        <Button
          android:id="@+id/btn_close"
          style="?attr/materialIconButtonFilledStyle"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:layout_marginStart="@dimen/margin_each_item"
          android:contentDescription="@string/close"
          android:insetLeft="0dp"
          android:insetTop="0dp"
          android:insetRight="0dp"
          android:insetBottom="0dp"
          android:minWidth="0dp"
          android:minHeight="0dp"
          android:paddingVertical="8dp"
          android:paddingLeft="10dp"
          android:paddingRight="8dp"
          android:theme="@style/ThemeOverlay.App.Button"
          app:icon="@drawable/ic_left_icon"
          app:iconPadding="0dp"
          app:iconTint="@color/yellow" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btn_toggle_layout"
          style="?attr/materialIconButtonFilledStyle"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:layout_gravity="end"
          android:layout_marginEnd="@dimen/margin_each_item"
          android:contentDescription="@string/toggle_list_layout"
          android:insetLeft="0dp"
          android:insetTop="0dp"
          android:insetRight="0dp"
          android:insetBottom="0dp"
          android:minWidth="0dp"
          android:minHeight="0dp"
          android:paddingVertical="8dp"
          android:paddingLeft="10.5dp"
          android:theme="@style/ThemeOverlay.App.Button"
          app:icon="@drawable/ic_grid"
          app:iconPadding="0dp"
          app:iconTint="@color/yellow" />

      </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.CollapsingToolbarLayout>
  </com.google.android.material.appbar.AppBarLayout>

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/rv_list"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:clipToPadding="false"
      android:contentDescription="@string/search_results"
      android:padding="8dp"
      tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
      tools:listitem="@layout/item_poster"
      tools:spanCount="3" />

  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  <include
    android:id="@+id/illustration_error"
    layout="@layout/illustration_error"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginTop="@dimen/margin_to_centered"
    android:visibility="gone"
    tools:visibility="visible" />

  <com.google.android.material.loadingindicator.LoadingIndicator
    android:id="@+id/loading_indicator"
    style="@style/MyProgressBar"
    tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>