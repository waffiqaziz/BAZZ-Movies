<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/container"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:padding="12dp">

  <ImageView
    android:id="@+id/img_crew_photo"
    android:layout_width="52dp"
    android:layout_height="52dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent" />

  <TextView
    android:id="@+id/tv_crew_name"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:textStyle="bold"
    app:layout_constraintStart_toEndOf="@id/img_crew_photo"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="@id/img_crew_photo" />

  <TextView
    android:id="@+id/tv_crew_department"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:textColor="@color/gray_400"
    app:layout_constraintStart_toEndOf="@id/img_crew_photo"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@id/tv_crew_name" />

</androidx.constraintlayout.widget.ConstraintLayout>