<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/coordinator_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".ui.fragment.MovieFragment">

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/swipe_refresh_movie"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
      android:id="@+id/nested_scroll_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/bottom_nav_min_height">

        <!-- Popular -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_popular_movie"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="@dimen/default_margin_parent_20">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/popular" />

          <include
            android:id="@+id/btn_more_popular_movie"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_popular_movie"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_wide" />

        <!-- Airing today-->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_movie_airing_today"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="16dp">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/now_playing" />

          <include
            android:id="@+id/btn_more_movie_airing_today"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <include
          android:id="@+id/layout_no_movie_airing_today"
          layout="@layout/no_found_layout"
          android:visibility="gone"
          tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_movie_airing_today"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.StaggeredGridLayoutManager"
          tools:layout_height="330dp"
          tools:listitem="@layout/item_poster"
          tools:spanCount="2" />

        <!-- Upcoming -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_upcoming_movie"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/upcoming" />

          <include
            android:id="@+id/btn_more_upcoming_movie"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <include
          android:id="@+id/layout_no_upcoming_movie"
          layout="@layout/no_found_layout"
          android:visibility="gone"
          tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_upcoming_movie"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

        <!-- Top-rated-->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_top_rated_movie"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/top_rated" />

          <include
            android:id="@+id/btn_more_top_rated_movie"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_top_rated_movie"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

      </LinearLayout>
    </androidx.core.widget.NestedScrollView>
  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  <include
    android:id="@+id/shimmer"
    layout="@layout/shimmer_movie"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone" />

  <include
    android:id="@+id/illustration_error_movie"
    layout="@layout/illustration_error"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginBottom="@dimen/margin_to_centered"
    android:visibility="gone"
    tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>