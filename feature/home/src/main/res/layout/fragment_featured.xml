<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/fragment_featured"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".ui.FeaturedFragment">

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/swipe_refresh_featured"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
      android:id="@+id/nested_scroll_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/bottom_nav_min_height">

        <ImageView
          android:id="@+id/img_main_featured"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:adjustViewBounds="true"
          android:contentDescription="@string/featured"
          android:foreground="@drawable/bg_gradient_shape"
          tools:layout_height="250dp"
          tools:src="@color/red_matte" />

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="-20dp"
          android:orientation="vertical"
          tools:ignore="NegativeMargin">

          <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/layout_header_trending_featured"
            style="@style/LayoutHeaderTheme">

            <TextView
              style="@style/TextHeader2"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center_vertical"
              android:text="@string/trending" />

            <include
              android:id="@+id/btn_more_trending_featured"
              layout="@layout/button_more"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="end|center"
              android:layout_marginEnd="-4dp" />

          </androidx.coordinatorlayout.widget.CoordinatorLayout>

          <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/button_group"
            style="@style/FilterButtonGroupStyle"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="@dimen/default_margin_parent_20">

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_trending_today"
              style="@style/FilterToggleOverlay"
              android:text="@string/today" />

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_trending_this_week"
              style="@style/FilterToggleOverlay"
              android:checked="true"
              android:text="@string/this_week" />

          </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <include
          android:id="@+id/layout_no_trending"
          layout="@layout/no_found_layout"
          android:visibility="gone"
          tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_trending"
          style="@style/HomeRecyclerView"
          android:contentDescription="@string/trending"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

        <!-- Upcoming-->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_upcoming_movie_featured"
          style="@style/LayoutHeaderTheme">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/upcoming_movies" />

          <include
            android:id="@+id/btn_more_upcoming_movie_featured"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <include
          android:id="@+id/layout_no_upcoming"
          layout="@layout/no_found_layout"
          android:visibility="gone"
          tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_upcoming_movie_featured"
          style="@style/HomeRecyclerView"
          android:contentDescription="@string/upcoming_movies"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

        <!-- Playing now -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_movie_playing_now_featured"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextHeader2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/playing_now_on_theater" />

          <include
            android:id="@+id/btn_more_movie_playing_now_featured"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|end"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <include
          android:id="@+id/layout_no_playing"
          layout="@layout/no_found_layout"
          android:visibility="gone"
          tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_movie_playing_now_featured"
          style="@style/HomeRecyclerView"
          android:contentDescription="@string/playing_now_on_theater"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />
      </LinearLayout>

    </androidx.core.widget.NestedScrollView>

  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  <include
    android:id="@+id/illustration_error_featured"
    layout="@layout/illustration_error"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginBottom="@dimen/margin_to_centered"
    android:visibility="gone"
    tools:visibility="invisible" />

  <include
    android:id="@+id/shimmer"
    layout="@layout/shimmer_featured"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>