<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/coordinator_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".ui.fragment.TvSeriesFragment">

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/swipe_refresh_asian"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
      android:id="@+id/nested_scroll_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/bottom_nav_min_height">

        <LinearLayout
          android:id="@+id/layout_header_anime"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/default_margin_parent_20"
          android:orientation="vertical"
          tools:ignore="NegativeMargin">

          <androidx.coordinatorlayout.widget.CoordinatorLayout
            style="@style/LayoutHeaderTheme">

            <TextView
              style="@style/TextAppearance.App.Header2"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center_vertical"
              android:text="@string/anime" />

            <include
              android:id="@+id/btn_more_anime"
              layout="@layout/button_more"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="end|center"
              android:layout_marginEnd="-4dp" />

          </androidx.coordinatorlayout.widget.CoordinatorLayout>

          <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/button_group"
            style="@style/Widget.App.ButtonGroup.Filter"
            android:layout_marginHorizontal="@dimen/default_margin_parent_20"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_anime_this_season"
              style="@style/Widget.App.Button.FilterToggle"
              android:checked="true"
              android:text="@string/this_season" />

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_anime_all_time"
              style="@style/Widget.App.Button.FilterToggle"
              android:text="@string/all_time" />

          </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_anime"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_wide" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_costume_drama"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextAppearance.App.Header2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/costume_drama" />

          <include
            android:id="@+id/btn_more_costume_drama"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_costume_drama"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_romance_drama"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextAppearance.App.Header2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/romance_drama" />

          <include
            android:id="@+id/btn_more_romance_drama"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_romance_drama"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.StaggeredGridLayoutManager"
          tools:layout_height="330dp"
          tools:listitem="@layout/item_poster"
          tools:spanCount="2" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_reality_show"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextAppearance.App.Header2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/reality_show" />

          <include
            android:id="@+id/btn_more_reality_show"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_reality_show"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:id="@+id/layout_header_donghua"
          style="@style/LayoutHeaderTheme"
          android:layout_marginTop="12dp">

          <TextView
            style="@style/TextAppearance.App.Header2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/donghua" />

          <include
            android:id="@+id/btn_more_donghua"
            layout="@layout/button_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:layout_marginEnd="-4dp" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_donghua"
          style="@style/HomeRecyclerView"
          tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
          tools:layout_height="150dp"
          tools:listitem="@layout/item_poster" />

      </LinearLayout>
    </androidx.core.widget.NestedScrollView>
  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  <include
    android:id="@+id/shimmer_layout_asian"
    layout="@layout/shimmer_asian"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone" />

  <include
    android:id="@+id/illustration_error_asian"
    layout="@layout/illustration_error"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginBottom="@dimen/margin_to_centered"
    android:visibility="gone"
    tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>