<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".ui.AboutActivity">

  <!-- ========================== -->
  <!--        HEADER SECTION      -->
  <!-- ========================== -->
  <com.google.android.material.appbar.AppBarLayout
    android:id="@+id/app_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="?attr/colorPrimary"
      android:minHeight="0dp">

      <Button
        android:id="@+id/btn_back"
        style="@style/BackButton"
        android:layout_marginRight="@dimen/margin_each_item" />

      <include layout="@layout/custom_toolbar_item" />

    </com.google.android.material.appbar.MaterialToolbar>
  </com.google.android.material.appbar.AppBarLayout>
  <!-- End of HEADER SECTION -->

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="80dp"
    android:background="@color/gray_900"
    android:orientation="vertical"
    android:paddingTop="@dimen/margin_between_item"
    android:paddingHorizontal="@dimen/default_margin_parent_20"
    tools:context=".ui.AboutActivity">

    <!-- ========================== -->
    <!--         BODY SECTION       -->
    <!-- ========================== -->
    <TextView
      android:id="@+id/tv_about_header"
      style="@style/TextHeader1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/about" />

    <TextView
      android:id="@+id/tv_tmdb_attribute"
      style="@style/TextBody"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="@string/tmdb_endorse" />

    <!-- ====== TMDB logo ====== -->
    <ImageView
      android:id="@+id/iv_tmdb_logo"
      android:layout_width="80dp"
      android:layout_height="80dp"
      android:layout_gravity="center"
      android:contentDescription="@string/tmdb_full"
      android:background="?attr/selectableItemBackgroundBorderless"
      android:src="@drawable/ic_tmdb" />

    <TextView
      android:id="@+id/tv_about_text"
      style="@style/TextBody"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/about_text" />

    <!-- ====== About button ====== -->
    <com.google.android.material.button.MaterialButton
      android:id="@+id/btn_about_us"
      style="@style/MyTransparentButton"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="20dp"
      android:text="@string/about_us" />
    <!-- End of BODY SECTION -->

  </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
